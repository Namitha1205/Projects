import java.util.*;
public class UndoRedoEditor {
    static Stack<String> undoStack = new Stack<>();
    static Stack<String> redoStack = new Stack<>();
    static String text = "";
    static Scanner sc = new Scanner(System.in);
    // Type text
    static void typeText(String newText) {
        undoStack.push(text);  // save current state
        text += newText;
        redoStack.clear();     // clear redo after new action
    }
    // Undo
    static void undo() {
        if (!undoStack.isEmpty()) {
            redoStack.push(text);
            text = undoStack.pop();
        } else {
            System.out.println("Nothing to undo!");
        }
    }
    // Redo
    static void redo() {
        if (!redoStack.isEmpty()) {
            undoStack.push(text);
            text = redoStack.pop();
        } else {
            System.out.println("Nothing to redo!");
        }
    }
    // Display text
    static void display() {
        System.out.println("Current Text: " + text);
    }
    public static void main(String[] args) {
        int choice;
        do {
            System.out.println("\n===== Text Editor =====");
            System.out.println("1. Type Text");
            System.out.println("2. Undo");
            System.out.println("3. Redo");
            System.out.println("4. Display");
            System.out.println("5. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();
            sc.nextLine(); // clear buffer
            switch (choice) {
                case 1:
                    System.out.print("Enter text: ");
                    String input = sc.nextLine();
                    typeText(input);
                    break;

                case 2:
                    undo();
                    break;

                case 3:
                    redo();
                    break;

                case 4:
                    display();
                    break;

                case 5:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }
        } while (choice != 5);
    }
}
